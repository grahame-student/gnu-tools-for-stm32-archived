# Autotools generated files
# These files are regenerated during the build process using autoreconf/autoconf/automake

# Configure scripts generated by autoconf
configure
# EXCEPTION: fixincludes/configure is maintained as a source file
!fixincludes/configure

# Makefile templates generated by automake or autogen
Makefile.in

# EXCEPTIONS: The following Makefile.in files are manually maintained source files, NOT generated:
!c++tools/Makefile.in
!fixincludes/Makefile.in
!gcc/Makefile.in
!gcc/ada/Makefile.in
!gcc/ada/gcc-interface/Makefile.in
!gnattools/Makefile.in
!intl/Makefile.in
!libada/Makefile.in
!libcody/Makefile.in
!libcpp/Makefile.in
!libdecnumber/Makefile.in
!libgcc/Makefile.in
!libiberty/Makefile.in
!libiberty/testsuite/Makefile.in
!libobjc/Makefile.in
!libvtv/testsuite/other-tests/Makefile.in

# Aclocal macro collections
aclocal.m4
# EXCEPTION: fixincludes/aclocal.m4 is maintained as a source file
!fixincludes/aclocal.m4

# Config header templates generated by autoheader
config.h.in
# EXCEPTION: fixincludes/config.h.in is maintained as a source file
!fixincludes/config.h.in
