# Automake-generated files - these are regenerated during the build process
# for bootstrap libraries (GMP, MPFR, MPC, ISL, EXPAT, libiconv)

# Generated by autoconf
**/configure

# Generated by autoheader
**/config.h.in
**/config.in

# Generated by automake
**/Makefile.in
# Exception: libiconv uses hand-crafted Makefile.in files (not automake-generated)
# Only srclib/Makefile.in is automake-generated in libiconv 
!/libiconv/Makefile.in
!/libiconv/lib/Makefile.in
!/libiconv/libcharset/Makefile.in
!/libiconv/libcharset/lib/Makefile.in
!/libiconv/man/Makefile.in
!/libiconv/preload/Makefile.in
!/libiconv/src/Makefile.in
!/libiconv/tests/Makefile.in
# Exception: binutils subdirectories that don't use automake have hand-crafted Makefile.in
!/binutils/libiberty/Makefile.in
!/binutils/libiberty/testsuite/Makefile.in
!/binutils/libdecnumber/Makefile.in
!/binutils/gdb/Makefile.in
!/binutils/gdb/data-directory/Makefile.in
!/binutils/gdb/doc/Makefile.in
!/binutils/gdb/testsuite/Makefile.in
!/binutils/gdbserver/Makefile.in
# Exception: GCC subdirectories that don't use automake have hand-crafted Makefile.in
!/gcc/c++tools/Makefile.in
!/gcc/fixincludes/Makefile.in
!/gcc/gcc/Makefile.in
!/gcc/gcc/ada/Makefile.in
!/gcc/gcc/ada/gcc-interface/Makefile.in
!/gcc/gnattools/Makefile.in
!/gcc/intl/Makefile.in
!/gcc/libada/Makefile.in
!/gcc/libcody/Makefile.in
!/gcc/libcpp/Makefile.in
!/gcc/libdecnumber/Makefile.in
!/gcc/libgcc/Makefile.in
!/gcc/libiberty/Makefile.in
!/gcc/libiberty/testsuite/Makefile.in
!/gcc/libobjc/Makefile.in

# Generated by aclocal
**/aclocal.m4

# Auxiliary build files (copied by automake or libtoolize)
**/config.guess
**/config.sub
**/install-sh
**/missing
**/depcomp
**/compile
**/test-driver
**/ltmain.sh
**/ylwrap

# Build artifacts (should not be in repo anyway)
**/config.h
**/config.log
**/config.status
**/Makefile
**/.deps/
**/.libs/
**/*.o
**/*.lo
**/*.la
**/*.a
**/*.so
**/*.so.*
**/*.dylib
**/autom4te.cache/
**/*~
**/*.info
**/*.info-*
**/ar-lib
