# Automake-generated files - these are regenerated during the build process
# for bootstrap libraries (GMP, MPFR, MPC, ISL, EXPAT, libiconv)

# Generated by autoconf
**/configure

# Generated by autoheader
**/config.h.in
**/config.in

# Generated by automake
**/Makefile.in
# Exception: libiconv uses hand-crafted Makefile.in files (not automake-generated)
# Only srclib/Makefile.in is automake-generated in libiconv
!/libiconv/Makefile.in
!/libiconv/lib/Makefile.in
!/libiconv/libcharset/Makefile.in
!/libiconv/libcharset/lib/Makefile.in
!/libiconv/man/Makefile.in
!/libiconv/preload/Makefile.in
!/libiconv/src/Makefile.in
!/libiconv/tests/Makefile.in

# Generated by aclocal
**/aclocal.m4

# Auxiliary build files (copied by automake or libtoolize)
**/config.guess
**/config.sub
**/install-sh
**/missing
**/depcomp
**/compile
**/test-driver
**/ltmain.sh

# Build artifacts (should not be in repo anyway)
**/config.h
**/config.log
**/config.status
**/Makefile
**/.deps/
**/.libs/
**/*.o
**/*.lo
**/*.la
**/*.a
**/*.so
**/*.so.*
**/*.dylib
**/autom4te.cache/
**/*~
