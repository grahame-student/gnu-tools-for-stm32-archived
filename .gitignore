# Build directories
build-native/
build-mingw/
install-native/
install-mingw/

# Package directory
pkg/

# Autogenerated files in GMP library
# These files are regenerated by the build scripts using autoreconf
# Note: Similar patterns should be added for other bootstrap libraries (mpfr, mpc, isl, expat, libiconv) as they are processed
src/gmp/configure
src/gmp/Makefile.in
src/gmp/aclocal.m4
src/gmp/config.h.in
src/gmp/config.in
src/gmp/*~
src/gmp/compile
src/gmp/config.guess
src/gmp/config.sub
src/gmp/depcomp
src/gmp/install-sh
src/gmp/ltmain.sh
src/gmp/missing
src/gmp/test-driver
src/gmp/ar-lib
src/gmp/py-compile
src/gmp/autom4te.cache/
# Subdirectories also contain generated Makefile.in files (e.g., cxx/, mpf/, mpz/, mpq/, tests/, etc.)
src/gmp/**/Makefile.in
src/gmp/**/configure
src/gmp/**/config.h.in
