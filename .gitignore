# Automake and autoconf generated files
# These should be regenerated during the build process
/src/**/configure
/src/**/Makefile.in
/src/**/aclocal.m4
/src/**/config.h.in
/src/**/autom4te.cache/

# Exception: zlib uses hand-written configure and Makefile.in (not autotools)
!/src/zlib-1.2.12/configure
!/src/zlib-1.2.12/Makefile.in

# Exception: Top-level auxiliary files for complex multi-directory projects
# These files are needed at the top level and are not reliably regenerated by autoreconf
!/src/binutils/install-sh
!/src/binutils/missing
!/src/binutils/depcomp
!/src/binutils/compile
!/src/binutils/config.guess
!/src/binutils/config.sub
!/src/binutils/ltmain.sh
!/src/binutils/ar-lib
!/src/gcc/install-sh
!/src/gcc/missing
!/src/gcc/depcomp
!/src/gcc/compile
!/src/gcc/config.guess
!/src/gcc/config.sub
!/src/gcc/ltmain.sh
!/src/gcc/ar-lib
!/src/gdb/install-sh
!/src/gdb/missing
!/src/gdb/depcomp
!/src/gdb/compile
!/src/gdb/config.guess
!/src/gdb/config.sub
!/src/gdb/ltmain.sh
!/src/gdb/ar-lib
!/src/newlib/install-sh
!/src/newlib/missing
!/src/newlib/depcomp
!/src/newlib/compile
!/src/newlib/config.guess
!/src/newlib/config.sub
!/src/newlib/ltmain.sh
!/src/newlib/ar-lib
!/src/newlib/test-driver
!/src/newlib/ylwrap

# Auxiliary scripts generated by automake/libtool
/src/**/compile
/src/**/depcomp
/src/**/install-sh
/src/**/missing
/src/**/ylwrap
/src/**/ar-lib
/src/**/test-driver
/src/**/config.guess
/src/**/config.sub
/src/**/ltmain.sh

# Build directories and artifacts
build-*/
*.o
*.a
*.so
*.lo
*.la
.libs/
.deps/
Makefile
config.status
config.log
libtool
stamp-h1
